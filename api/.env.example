DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/campuslife
JWT_SECRET=change-me-to-a-random-string
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
# OAuth Client IDs from Google Cloud Console. Each platform's native SDK
# issues an ID token whose audience (aud) is that platform's own client ID,
# so the backend needs all of them to accept sign-ins from every platform.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# 忘記密碼寄信用（例如 Gmail 應用程式密碼）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
