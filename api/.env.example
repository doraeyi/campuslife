DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/campuslife
JWT_SECRET=change-me-to-a-random-string
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
# OAuth Client ID from Google Cloud Console (the "Web client" ID — this is the
# audience that Google ID tokens from the app must be issued for, regardless
# of whether the token came from the Android/iOS client)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
